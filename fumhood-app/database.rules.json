{
  "rules": {
    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() == true"
      }
    },

    "users": {
      ".read":  "auth != null",
      "$uid": {
        ".read":  "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "devices": {
      ".read":  "auth != null",
      "$deviceId": {
        ".read":  "true",
        ".write": "true",

        "owner": {
          ".validate": "newData.isString()"
        },
        "status": {
          ".write": "true",
          ".read":  "true",
          ".indexOn": ["timestamp"]
        },
        "commands": {
          ".read":  "true",
          ".write": "true"
        },
        "schedules": {},
        "nvsSchedule": {}
      }
    }
  }
}
